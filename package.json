{
  "name": "nexussphere",
  "version": "1.0.0",
  "private": true,
  "description": "NexusSphere - Intent-Centric AI Financial Agent Monorepo",
  "workspaces": [
    "bot",
    "web"
  ],
  "scripts": {
    "bot": "npm run dev --workspace=bot",
    "web": "npm run dev --workspace=web",
    "dev": "concurrently \"npm run bot\" \"npm run web\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
