# NexusSphere — Environment Variables
# Copy this file to .env and fill in your actual values.

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Model to use (options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o

# ── Web Dashboard ─────────────────────────────────────────────────────────────
# WalletConnect project ID (create one at https://cloud.walletconnect.com)
# Required for multi-wallet support. Without it, basic MetaMask still works.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Optional: absolute path to the SQLite DB file (defaults to ../bot/nexussphere.db)
# DB_PATH=/absolute/path/to/nexussphere.db
