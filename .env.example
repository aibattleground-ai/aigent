# AIGENT — Environment Variables
# Copy this file to .env and fill in your actual values.

# ── Telegram Bot ────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Anthropic Claude AI ─────────────────────────────────────────────────────
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (recommended: claude-3-5-sonnet-20241022)
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── Web Dashboard ───────────────────────────────────────────────────────────
# WalletConnect project ID (https://cloud.walletconnect.com) - optional for MetaMask
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Optional: absolute path to the JSON DB file (defaults to ../bot/nexussphere-db.json)
# DB_PATH=/absolute/path/to/aigent-db.json
