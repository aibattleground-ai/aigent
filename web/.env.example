# ==========================================
# NEXUSSPHERE - AIGENT
# Vercel Deployment Environment Variables
# ==========================================

# 1. Telegram Bot (Create a bot via BotFather on Telegram)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# 2. Claude AI Agent
ANTHROPIC_API_KEY="your_anthropic_api_key"
CLAUDE_MODEL="claude-3-5-sonnet-latest"

# 3. Hyperliquid Integration
# Set to 'true' to actually execute trades on Hyperliquid. Default is false (mock trades).
LIVE_TRADING="true"
HYPERLIQUID_PRIVATE_KEY="your_wallet_private_key_matching_hyperliquid"

# 4. Vercel KV Database (For production memory instead of local JSON)
# These will be automatically populated by Vercel if you go to Vercel > Storage > Create KV Database
KV_URL=""
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
KV_REST_API_READ_ONLY_TOKEN=""

# 5. Vercel Cron Job Security
# A secret string to prevent unauthorized firing of the cron job
CRON_SECRET="generate_a_random_strong_secret_string"
